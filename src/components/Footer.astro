---
// src/components/Footer.astro
import { client } from '../lib/prismic';

const settingsData = await client.getSingle('settings').catch(() => null);

const logoUrl = settingsData?.data?.logo_nome?.url || '/logo-nome.svg';
const logoAlt = settingsData?.data?.site_title || 'Carolina Alves';
const email = settingsData?.data?.email || 'contato@carolinaalves.com.br';
const endereco = settingsData?.data?.endereco || 'Av. Mato Grosso, 2308 - Salão 2 - Jardim dos Estados, Campo Grande - MS, 79020-201';
const whatsappNumber = '5567992890225';
const currentYear = new Date().getFullYear();
---

<footer class="footer">
  <div class="footer__bg-overlay"></div>

  <div class="footer__inner">
    <!-- Logo -->
    <div class="footer__logo">
      <img src={logoUrl} alt={logoAlt} class="footer__logo-img" />
    </div>

    <!-- Grid 3 colunas -->
    <nav class="footer__grid" aria-label="Footer">
      <div class="footer__col">
        <h4 class="footer__col-title">Navegação</h4>
        <ul class="footer__links">
          <li><a href="#hero">Início</a></li>
          <li><a href="#pacotes">Portfolio</a></li>
          <li><a href="#historias">Histórias</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4 class="footer__col-title">Especialidades</h4>
        <ul class="footer__links">
          <li><a href="#pacotes">Ensaios</a></li>
          <li><a href="#pacotes">Momentos</a></li>
          <li><a href="#pacotes">Eventos</a></li>
        </ul>
      </div>

      <div class="footer__col">
        <h4 class="footer__col-title">Contato</h4>
        <ul class="footer__links footer__links--contact">
          <li>
            <a href={`https://wa.me/${whatsappNumber}`} target="_blank" rel="noopener noreferrer">
              <svg class="footer__contact-icon" viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
                <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
              </svg>
              WhatsApp
            </a>
          </li>
          <li>
            <a href={`mailto:${email}`}>
              <svg class="footer__contact-icon" viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
                <path d="M20 4H4c-1.1 0-2 .9-2 2v12c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
              </svg>
              {email}
            </a>
          </li>
          <li class="footer__address">
            <svg class="footer__contact-icon" viewBox="0 0 24 24" fill="currentColor" width="16" height="16">
              <path d="M12 2C8.13 2 5 5.13 5 9c0 5.25 7 13 7 13s7-7.75 7-13c0-3.87-3.13-7-7-7zm0 9.5c-1.38 0-2.5-1.12-2.5-2.5s1.12-2.5 2.5-2.5 2.5 1.12 2.5 2.5-1.12 2.5-2.5 2.5z"/>
            </svg>
            <span>{endereco}</span>
          </li>
        </ul>
      </div>
    </nav>

    <!-- Follow us -->
    <div class="footer__social-box">
      <span class="footer__social-label">Follow us</span>
      <div class="footer__social-icons">
        <a href="https://www.instagram.com/carolinaalvesfoto/" target="_blank" rel="noopener noreferrer" aria-label="Instagram">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zM12 0C8.741 0 8.333.014 7.053.072 2.695.272.273 2.69.073 7.052.014 8.333 0 8.741 0 12c0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98C8.333 23.986 8.741 24 12 24c3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98C15.668.014 15.259 0 12 0zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/></svg>
        </a>
        <a href="https://www.facebook.com/carolinalvesfoto/" target="_blank" rel="noopener noreferrer" aria-label="Facebook">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
        </a>
        <a href="https://www.linkedin.com/in/carolinaalvesfoto/" target="_blank" rel="noopener noreferrer" aria-label="LinkedIn">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/></svg>
        </a>
        <a href={`https://wa.me/${whatsappNumber}`} target="_blank" rel="noopener noreferrer" aria-label="WhatsApp">
          <svg viewBox="0 0 24 24" fill="currentColor"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/></svg>
        </a>
      </div>
    </div>
  </div>

  <!-- Barra legal -->
  <div class="footer__bottom">
    <span>&copy; {currentYear} Carolina Alves. Todos os direitos reservados.</span>
    <a href="/termos">Termos de Serviço</a>
    <a href="https://github.com/JoseWilliamRF" target="_blank" rel="noopener noreferrer" class="footer__credit">Code by José William</a>
  </div>
</footer>

<style>
  .footer {
    position: relative;
    z-index: 5;
    width: 100vw;
    min-height: 320px;
    overflow: hidden;
    color: #000;
    font-family: var(--font-sans);
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    background: rgba(255, 255, 255, 0.03);
  }

  /* Vidro — mesmo efeito do Header */
  .footer__bg-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.06) 0%,
      rgba(255, 255, 255, 0.02) 40%,
      rgba(255, 255, 255, 0.04) 100%
    );
    backdrop-filter: blur(4px) saturate(140%) brightness(1.02);
    -webkit-backdrop-filter: blur(4px) saturate(140%) brightness(1.02);
    box-shadow:
      0 0 0 1px rgba(244, 244, 244, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
    pointer-events: none;
    z-index: 1;

    /* Estado inicial da animação */
    clip-path: inset(100% 0 0 0);
  }

  .footer__inner {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1600px;
    padding: 2rem 5% 1.5rem;
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1.75rem;

    /* Estado inicial da animação */
    transform: translateY(80px);
    clip-path: inset(100% 0 0 0);
  }

  /* Logo — forçada a preto independente do SVG original */
  .footer__logo-img {
    height: 80px;
    width: auto;
    opacity: 1;
    filter: brightness(0);
    
  }
  .footer__logo {
  margin-left: -35%; }

  /* Grid */
  .footer__grid {
    display: grid;
    grid-template-columns: repeat(4, 1fr);
    gap: 1.5rem;
    width: 100%;
  }

  .footer__col-title {
    font-size: 0.8rem;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: 0.08em;
    margin-bottom: 0.75rem;
    color: #000;
  }

  .footer__links {
    list-style: none;
    padding: 0;
    margin: 0;
    display: flex;
    flex-direction: column;
    gap: 0.4rem;
  }

  .footer__links a {
    color: #000;
    text-decoration: none;
    font-size: 0.85rem;
    transition: opacity 0.25s ease;
    display: inline-flex;
    align-items: center;
    gap: 0.5rem;
  }

  .footer__links a:hover {
    opacity: 0.7;
  }

  .footer__contact-icon {
    flex-shrink: 0;
    opacity: 1;
  }

  .footer__address span {
    line-height: 1.5;
  }

  /* ─── Follow us box (glass = Header) ─── */
  .footer__social-box {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 0.75rem;
    padding: 0.75rem 2rem;
    border-radius: 8px;

    /* Mesmo glass do Header */
    background: linear-gradient(
      180deg,
      rgba(255, 255, 255, 0.06) 0%,
      rgba(255, 255, 255, 0.02) 40%,
      rgba(255, 255, 255, 0.04) 100%
    );
    backdrop-filter: blur(4px) saturate(140%) brightness(1.02);
    -webkit-backdrop-filter: blur(4px) saturate(140%) brightness(1.02);
    box-shadow:
      0 0 0 1px rgba(244, 244, 244, 0.15),
      inset 0 1px 0 rgba(255, 255, 255, 0.08);
  }

  .footer__social-label {
    font-size: 0.7rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: #000;
  }

  .footer__social-icons {
    display: flex;
    gap: 1rem;
  }

  .footer__social-icons a {
    color: #000;
    transition: opacity 0.25s ease, transform 0.25s ease;
    display: flex;
    align-items: center;
  }

  .footer__social-icons a:hover {
    opacity: 0.7;
    transform: translateY(-2px);
  }

  .footer__social-icons svg {
    width: 20px;
    height: 20px;
  }

  /* Barra inferior */
  .footer__bottom {
    position: relative;
    z-index: 2;
    width: 100%;
    max-width: 1600px;
    padding: 0.75rem 5%;
    border-top: 1px solid rgba(26, 26, 26, 0.1);
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 2rem;
    font-size: 0.72rem;
    color: #000;
    flex-wrap: wrap;

    /* Estado inicial da animação */
    transform: translateY(30px);
    clip-path: inset(100% 0 0 0);
  }

  .footer__bottom a {
    color: #000;
    text-decoration: none;
    transition: opacity 0.25s ease;
  }

  .footer__bottom a:hover {
    opacity: 0.7;
  }

  .footer__credit {
    font-weight: 500;
  }

  /* Mobile */
  @media (max-width: 768px) {
    .footer {
      min-height: auto;
    }

    .footer__inner {
      padding: 2rem 5% 1.25rem;
      gap: 1.25rem;
    }

    .footer__grid {
      grid-template-columns: 1fr;
      gap: 1.25rem;
      text-align: center;
    }

    .footer__links--contact {
      align-items: center;
    }

    .footer__social-box {
      padding: 0.6rem 1.25rem;
    }

    .footer__bottom {
      flex-direction: column;
      gap: 0.5rem;
      text-align: center;
    }
  }
</style>
