  <style>

    /* RESET DE BOTÕES BÁSICO */
    button {
      background: none;
      border: none;
      padding: 0;
      cursor: pointer;
      color: inherit;
      font: inherit;
    }

    /* ESTRUTURA PRINCIPAL */
    .header {
      
      position: fixed;
      top: 0;
      left: 0;
      width: 100%;
      z-index: 100;
      padding: 2rem 3rem 1.5rem;
      color: var(--header-text-color);
    }
    
.header__glass {
  position: absolute;
  top: 0;
  left: 0;
  width: 100%;
  height: 100%;
  
  /* Aquoso: gradiente sutil + saturate + brightness */
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.06) 0%,
    rgba(255, 255, 255, 0.02) 40%,
    rgba(255, 255, 255, 0.04) 100%
  );
  backdrop-filter: blur(4px) saturate(140%) brightness(1.02);
  -webkit-backdrop-filter: blur(4px) saturate(140%) brightness(1.02);
  box-shadow:
    0 0 0 1px rgba(244, 244, 244, 0.15),
    inset 0 1px 0 rgba(255, 255, 255, 0.08);

  /* Mantém as âncoras para a animação do GSAP */
  transform: scaleY(0);
  transform-origin: top;
  z-index: -1;
  pointer-events: none;
}


  .header__left,
  .header__right {
    align-items: center;
    display: flex;
    gap: 0.5rem;
  }

  .header__left,
  .header__center,
  .header__right {
    will-change: transform;
  }

    .header__container {
      display: flex;
      align-items: center;
      justify-content: space-between;
      width: 100%;
      position: relative; /* Define o limite do absolute da logo */
    }

    .header__center {
      position: absolute;
      left: 50%;
      transform: translateX(-50%);
      display: flex;
      align-items: center;
      justify-content: center;
    }

    .header__logo-text {
    display: inline-block;
    white-space: nowrap;
    overflow: hidden;
    clip-path: inset(0 0 0 0); /* inicialmente totalmente visível */
  }
.header__logo-mobile {
  display: none;
  height: 4.5rem;          /* ajuste conforme o tamanho desejado */
  width: auto;
}
    
    
    /* TIPOGRAFIA E ELEMENTOS */
    .header__link {
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.05em;
      text-transform: uppercase;
      text-decoration: none;
      color: var(--header-text-color);
      opacity: 0.9;
      transition: opacity 0.3s ease;
    }

    .header__link:hover {
      opacity: 1;
    }



    /* BOTÃO MENU HAMBÚRGUER */
    .header__menu-btn {
      display: flex;
      align-items: center;
      gap: 0.75rem;
      font-size: 0.75rem;
      font-weight: 500;
      letter-spacing: 0.05em;
      padding: 10px;
      margin: -10px;
      cursor: pointer;
    }

    .menu-btn__icon {
      display: flex;
      flex-direction: column;
      gap: 5px;
      width: 28px;
    }

    .menu-btn__icon .line {
      display: block;
      width: 100%;
      height: 1.5px;
      background-color: var(--header-text-color);
      transition: transform 0.3s ease;
        
    }
    
    /* A linha de baixo no modelo é levemente mais curta */
    .menu-btn__icon .line:nth-child(2) {
      width: 70%; 
    }

  .header__logo {
    
      font-size: 2rem;
      font-weight: 400;
      color: var(--header-text-color);
      text-decoration: none;
      position: relative; /* OBRIGATÓRIO: Define as fronteiras para o ícone flutuar */
      display: inline-block; /* O centro da tela será cravado no centro exato da palavra */
    }
  .logo__icon {
      position: absolute;
      width: 75px;
      height: 75px;
      top: -30px;         /* Puxa para cima da linha do teto da palavra */
      left: 100%;         /* Trava a borda esquerda do ícone na borda direita da palavra */
      margin-left: -40px;  /* Ajuste fino empurrando levemente para a esquerda */
      z-index: 2;
    }

    /* BOTÃO FAVORITO (Coração) */
    .header__favorite-btn {
      display: flex;
      align-items: center;
      justify-content: center;
      opacity: 0.9;
      transition: opacity 0.3s ease;
    }

    .header__favorite-btn:hover {
      opacity: 1;
    }

    .favorite__icon {
      width: 20px;
      height: 20px;
    }
    
    /* Efeito de hover nos caracteres */
  :global(.word) {
    position: relative;
    display: inline-block;
  }

  :global(.word .before),
  :global(.word .after) {
    display: block;
  }

  :global(.word .before .char) {
    transform: translateY(0);
    transition: transform 0.33s ease-in-out;
  }

  :global(.word .after) {
    position: absolute;
    top: 0;
    left: 0;
  }

  :global(.word .after .char) {
    transform: translateY(-100%);
    transition: transform 0.33s ease-in-out;
  }

  :global(.word .after .char:nth-child(even)) {
    transform: translateY(100%);
  }

  :global(.word:hover .before .char) {
    transform: translateY(100%);
  }

  :global(.word:hover .before .char:nth-child(even)) {
    transform: translateY(-100%);
  }

  :global(.word:hover .after .char) {
    transform: translateY(0);
  }
    
  

  
.header__whatsapp-btn {
  display: flex;           
  align-items: center;
  justify-content: center;
  color: var(--header-text-color);
  width: 24px;             
  height: 24px;        
  opacity: 0.7;
  transition: opacity 0.3s ease, transform 0.3s ease;
}

.header__whatsapp-btn:hover {
  opacity: 1;
  transform: scale(1.15);
}

.whatsapp__icon {
  width: 100%;
  height: 100%;
}


@media (max-width: 768px) {
  .header {
    padding: 1rem 1.5rem;
  }
  .header__logo-text,
  .logo__icon {
    display: none;
  }

 .header__logo-mobile {
    display: block;
  }

  .header__right > .header__link {
    display: none;
  }

  .menu-btn__text {
    display: none;
  }

  .header__container {
    display: flex;
    align-items: center;

  }

  /* Logo à esquerda */
  .header__center {
    position: static;
    transform: none;
    order: 1;
    margin-right: auto;
  }

  .header__left,
  .header__right {
    display: contents; 
  }

  /* Ordem dos itens que ficarão à direita */
  .header__link {            /* PACOTES */
    order: 2;
    margin-left: 0;
    margin-right: 1rem;
  }
  .header__whatsapp-btn {    /* WhatsApp */
    order: 3;
    margin-right: 1rem;

    
  }
  .header__menu-btn {        /* MENU (hambúrguer) */
    order: 4;
  }

  /* Ajustes visuais */
  .header__logo { font-size: 1rem; }
  .logo__icon {
    width: 25px;
    height: 25px;
    top: -10px;
    margin-left: -3px;
  }
}

/* ═══════════════════════════════════════════ */
/* MOBILE NAV DROPDOWN                       */
/* ═══════════════════════════════════════════ */
.header__mobile-nav {
  position: fixed;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100dvh;
  z-index: 99;
  display: flex;
  align-items: center;
  justify-content: center;

  /* Escondido por padrão */
  visibility: hidden;
  pointer-events: none;
}

.header__mobile-nav.is-open {
  visibility: visible;
  pointer-events: auto;
}

.header__mobile-nav-glass {
  position: absolute;
  inset: 0;
  z-index: -1;

  /* Mesmo glass do Header */
  background: linear-gradient(
    180deg,
    rgba(255, 255, 255, 0.06) 0%,
    rgba(255, 255, 255, 0.02) 40%,
    rgba(255, 255, 255, 0.04) 100%
  );
  backdrop-filter: blur(4px) saturate(140%) brightness(1.02);
  -webkit-backdrop-filter: blur(4px) saturate(140%) brightness(1.02);
  box-shadow:
    0 0 0 1px rgba(244, 244, 244, 0.15),
    inset 0 1px 0 rgba(255, 255, 255, 0.08);

  /* Animação controlada por JS */
  transform: scaleY(0);
  transform-origin: top;
}

.header__mobile-links {
  list-style: none;
  padding: 0;
  margin: 0;
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 1.5rem;
  opacity: 0;
  transform: translateY(20px);
}

.header__mobile-links a {
  font-size: 1.25rem;
  font-weight: 500;
  letter-spacing: 0.06em;
  text-transform: uppercase;
  text-decoration: none;
  color: var(--header-text-color);
  transition: opacity 0.25s ease;
}

.header__mobile-links a:hover {
  opacity: 0.7;
}

.header__mobile-separator {
  width: 40px;
  height: 1px;
  background-color: var(--header-text-color);
  opacity: 0.3;
}

.header__mobile-cta {
  display: flex !important;
  align-items: center;
  gap: 0.5rem;
}

/* Hamburger → X */
.header__menu-btn.is-open .menu-btn__icon .line:nth-child(1) {
  transform: translateY(3.5px) rotate(45deg);
}

.header__menu-btn.is-open .menu-btn__icon .line:nth-child(2) {
  transform: translateY(-3px) rotate(-45deg);
  width: 100% !important;
}
  
    
  </style>

  <script>
    import gsap from 'gsap';
    import { ScrollTrigger } from 'gsap/ScrollTrigger';
    import { SplitText } from 'gsap/SplitText';    
    
    gsap.registerPlugin(ScrollTrigger, SplitText);

    document.addEventListener('DOMContentLoaded', () => {
      const header = document.querySelector('.header') as HTMLElement;
      const glass = document.querySelector('.header__glass') as HTMLElement;
      const logoText = document.querySelector('.header__logo-text') as HTMLElement;
      const logoIcon = document.querySelector('.logo__icon') as HTMLElement;

       // ========== ANIMAÇÕES DE SCROLL SEPARADAS POR BREAKPOINT ==========

      const mm = gsap.matchMedia();
      
     // Desktop: timeline completa (vidro, padding, wipe, ícone)
      
  mm.add("(min-width: 769px)", () => {
    
      if (!header || !glass || !logoText || !logoIcon) return;
        
        const textWidth = logoText.offsetWidth;
        
const tl = gsap.timeline({
          scrollTrigger: {
            trigger: document.body,
            start: 'top top',  // A transição começa no pixel zero da página
            end: '+=500',      // A zona de transição durará exatamente 200px de scroll
            scrub: 1,       // OBRIGATÓRIO: Amarra o avanço da animação à roda do mouse

          }
        });

        
      tl.to(glass, { scaleY: 1, autoAlpha: 1 }, 0)

        tl.to(header, {
          paddingTop: 30,
          paddingRight: 70,
          paddingBottom: 30,
          paddingLeft: 70,
        }, 0);
        
        tl.to(logoText, {
          clipPath: `inset(0 ${textWidth + 30}px 0 0)`, 
        }, 0);
        
        gsap.set(logoIcon, { scale: 30 / 50 });
        
        tl.to(logoIcon, {
          scale: 1,           
          top: "50%",         
          left: "50%",        
          xPercent: -50,      
          yPercent: -50,      
          marginLeft: 0       
        }, 0);
          return () => {
        tl.kill();
      };
      })
      
      // Mobile: apenas vidro e padding
      
// MOBILE (Física Unificada)
    mm.add("(max-width: 768px)", () => {
      if (!header || !glass) return;
      
      const tl = gsap.timeline({
        scrollTrigger: {
          trigger: document.body,
          start: 'top top',
          end: '+=150',      // Fim mais curto no mobile (telas menores)
          scrub: 1,          // Mantém a fricção física

        }
      });

      tl.to(glass, { scaleY: 1, autoAlpha: 1 }, 0);
      tl.to(header, {
        paddingTop: 10, paddingRight: 30, paddingBottom: 10, paddingLeft: 30,
      }, 0);

      return () => {
        tl.kill();
      };
        
      })
      
    // EFEITO DE HOVER NOS TEXTOS DO HEADER
    
  const menuBtnText = document.querySelector('.menu-btn__text'); 
    const ctaLink = document.querySelector('.header__right .header__link');   
    
    const hoverTargets = [menuBtnText, ctaLink].filter(Boolean);
      
    hoverTargets.forEach(el => {
      const split = SplitText.create(el, {
        type: "chars,words",
        wordsClass: "word",
        charsClass: "char",
        mask: "words",
        autoSplit: true,
        onSplit: (self) => {
          self.words.forEach((word) => {
            const content = word.innerHTML;
            word.innerHTML = "";
            // Camada superior (original)
            const before = document.createElement("div");
            before.classList.add("before");
            before.innerHTML = content;
            // Camada inferior (duplicata escondida)
            const after = document.createElement("div");
            after.classList.add("after");
            after.innerHTML = content;
            after.setAttribute("aria-hidden", "true");

            word.append(before, after);
          });
        }
      });
    });
    
    // ========================================
    // TRANSIÇÃO DE COR DO HEADER (Hero → Pacotes)
    // ========================================
    const lenis = (window as any).lenisInstance;
    if (lenis) {
      const heroHeight = window.innerHeight;
      const startTransition = heroHeight * 0.7;
      const endTransition = heroHeight + window.innerHeight * 0.3;

      const light = { r: 244, g: 244, b: 244 };
      const dark  = { r: 13,  g: 13,  b: 13  };

      lenis.on('scroll', ({ scroll }: { scroll: number }) => {
        const raw = (scroll - startTransition) / (endTransition - startTransition);
        const t = Math.min(1, Math.max(0, raw));

        const r = Math.round(light.r + (dark.r - light.r) * t);
        const g = Math.round(light.g + (dark.g - light.g) * t);
        const b = Math.round(light.b + (dark.b - light.b) * t);

        document.documentElement.style.setProperty('--header-text-color', `rgb(${r},${g},${b})`);
        document.documentElement.style.setProperty('--color-text', `rgb(${r},${g},${b})`);
      });
    }

    // ========================================
    // LABEL DINÂMICO — fade simples
    // ========================================
    const navLabel = document.querySelector('.header__nav-label') as HTMLElement;

    if (navLabel && lenis) {
      const labels = ['INÍCIO', 'PORTFOLIO', 'HISTÓRIAS'];
      let activeIndex = 0;

      function getSectionIndex(): number {
        const p = document.querySelector('#pacotes');
        const h = document.querySelector('#historias');
        if (!p) return 0;
        if (p.getBoundingClientRect().top > 100) return 0;
        if (!h) return 1;
        if (h.getBoundingClientRect().top > 100) return 1;
        return 2;
      }

      lenis.on('scroll', () => {
        const idx = getSectionIndex();
        if (idx === activeIndex) return;
        activeIndex = idx;

        gsap.to(navLabel, { opacity: 0, duration: 0.2, onComplete: () => {
          navLabel.textContent = labels[idx];
          gsap.to(navLabel, { opacity: 1, duration: 0.2 });
        }});
      });
    }

    // ========================================
    // MOBILE MENU TOGGLE
    // ========================================
    const menuBtn = document.querySelector('.header__menu-btn') as HTMLElement;
    const mobileNav = document.querySelector('.header__mobile-nav') as HTMLElement;
    const navGlass = document.querySelector('.header__mobile-nav-glass') as HTMLElement;
    const navLinks = document.querySelector('.header__mobile-links') as HTMLElement;

    if (menuBtn && mobileNav && navGlass && navLinks) {
      let menuOpen = false;

      menuBtn.addEventListener('click', () => {
        menuOpen = !menuOpen;

        if (menuOpen) {
          menuBtn.classList.add('is-open');
          mobileNav.classList.add('is-open');
          gsap.to(navGlass, { scaleY: 1, duration: 0.4, ease: 'power3.inOut' });
          gsap.to(navLinks, { opacity: 1, y: 0, duration: 0.35, delay: 0.15 });
        } else {
          gsap.to(navLinks, { opacity: 0, y: 20, duration: 0.2 });
          gsap.to(navGlass, {
            scaleY: 0, duration: 0.35, ease: 'power3.inOut', delay: 0.1,
            onComplete: () => {
              menuBtn.classList.remove('is-open');
              mobileNav.classList.remove('is-open');
            },
          });
        }
      });

      // Fechar ao clicar em um link
      mobileNav.querySelectorAll('a').forEach(link => {
        link.addEventListener('click', () => {
          if (!menuOpen) return;
          menuOpen = false;
          gsap.to(navLinks, { opacity: 0, y: 20, duration: 0.15 });
          gsap.to(navGlass, {
            scaleY: 0, duration: 0.3, ease: 'power3.inOut', delay: 0.05,
            onComplete: () => {
              menuBtn.classList.remove('is-open');
              mobileNav.classList.remove('is-open');
            },
          });
        });
      });
    }

    });
  </script>