          </span>
          <span class="menu-btn__text">MENU</span>
        </button>
        <span class="header__link header__nav-label">INÍCIO</span>
      </div>

      <div class="header__center">
      <a href="/" class="header__logo" aria-label="Carolina Alves Fotografia">
        <span class="header__logo-text">
          <img 
            src="/logo-vetor.svg" 
            alt="Carolina Alves" 
            style="width: 100%; height: auto; display: block;"
          />
        </span>
        <img src="/logo-folha.svg" alt="" class="logo__icon" />

        <!-- 🆕 Logo mobile (escondido por padrão) -->
        <img 
          src="/logo-nome.svg" 
          alt="Carolina Alves" 
          class="header__logo-mobile"
        />
      </a>
      </div>

<div class="header__right">
  <span class="header__link" style="pointer-events: none;">RESERVAR MOMENTO</span>
  
  <a href="https://wa.me/5567992890225?text=Ol%C3%A1!%20Vim%20pelo%20site%20e%20gostaria%20de%20saber%20mais%20sobre%20os%20pacotes%20dispon%C3%ADveis." target="_blank" class="header__whatsapp-btn" aria-label="WhatsApp" rel="noopener noreferrer">
