---
// src/components/Hero.astro

// Array simulando proporções diferentes para gerar a assimetria visual.
// O 'ratio' dita a largura da imagem em relação à altura fixa da faixa.
const imagesTopBot = [
  { src: '../../public/imagens/ensaios/ensaios1.jpg', ratio: '3/4' },
  { src: '../../public/imagens/ensaios/ensaios2.jpg', ratio: '3/4' },
  { src: '../../public/imagens/ensaios/ensaios3.jpg', ratio: '3/4' },
  { src: '../../public/imagens/ensaios/ensaios4.jpg', ratio: '3/4' },
  { src: '../../public/imagens/ensaios/ensaios5.jpg', ratio: '3/4' }
];

const imagesMid = [
  { src: '../../public/imagens/ensaios/ensaios6.jpg', ratio: '3/4' },
  { src: '../../public/imagens/significados/momentos1.jpg', ratio: '3/4' },
  { src: '../../public/imagens/significados/momentos2.jpg', ratio: '3/4' },
  { src: '../../public/imagens/significados/momentos3.jpg', ratio: '3/4' },
  { src: '../../public/imagens/significados/momentos4.jpg', ratio: '3/4' }
];

// Multiplicamos por 3 para garantir que a faixa seja mais larga que a diagonal do monitor.
// Isso impede que o usuário veja o "fundo falso" antes do loop reiniciar.
const trackTopBot = [...imagesTopBot, ...imagesTopBot, ...imagesTopBot];
const trackMid = [...imagesMid, ...imagesMid, ...imagesMid];
---

<section class="hero" id="hero">
  <div class="hero__grid-wrapper">
    
    <div class="hero__track track-left track-small">
      {trackTopBot.map((item,index) => (
        <div class="hero__item" style={`aspect-ratio: ${item.ratio};`}>
          <img src={item.src} alt="" loading={index < 5 ? "eager" : "lazy"} draggable="false" />
        </div>
      ))}
    </div>

    <div class="hero__track track-right track-large">
      {trackMid.map((item,index) => (
        <div class="hero__item" style={`aspect-ratio: ${item.ratio};`}>
          <img src={item.src} alt="" loading={index < 5 ? "eager" : "lazy"} draggable="false" />
        </div>
      ))}
    </div>

    <div class="hero__track track-left track-small">
      {trackTopBot.map((item,index) => (
        <div class="hero__item" style={`aspect-ratio: ${item.ratio};`}>
          <img src={item.src} alt="" loading={index < 5 ? "eager" : "lazy"} draggable="false" />
        </div>
      ))}
    </div>

  </div>

  <div class="hero__overlay"></div>

  <div class="hero__content">
    <h1 class="hero__title">Carolina<br/>Alves</h1>
    <p class="hero__subtitle">Há 14 anos revelando a essência e a força feminina<br> em Campo Grande. Um espaço de acolhimento para<br> você se ver por inteiro e ressignificar sua história.</p>
  </div>
</section>
<style>
  :root {
    --hero-bg: #e7e7e7; 
    --hero-text: black; 
  }
 
  

  
  .hero {
    position: sticky;
    top: 0;
    width: 100vw;
    height: 100vh;
    overflow: hidden;
    background-color: var(--hero-bg);
    z-index: 1;
  }

  .next-section {
    position: relative;
    width: 100%;
    min-height: 100vh;
    background-color: #ffffff;
    z-index: 2; 
    padding: 100px 5%; 
  }

  .hero__grid-wrapper {
    position: absolute;
    top: 50%;
    left: 50%;
    
    transform: translate(-50%, -50%) rotate(-30deg);
    display: flex;
    flex-direction: column;
    gap: 2rem; /* Gap entre as faixas */
    width: 150vw; 
    justify-content: center;
    align-items: center;
  }

  .hero__track {
    display: flex;
    gap: 2rem; /* Gap entre as imagens */
    width: max-content; 
    will-change: transform;
  }

  /* Controle Assimétrico de Alturas */
  .track-small { height: 65vh; }
  .track-large { height: 80vh; }

  .hero__item {
    height: 100%; 
    background-color: rgba(255, 255, 255, 0.03);
    overflow: hidden;
  }

  .hero__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.6;
    transition: opacity 0.4s ease;
    user-drag: none;
    -webkit-user-drag: none;
    user-select: none;
    -webkit-user-select: none;
  }

  /* .hero__item:hover img {
    opacity: 1;
  } */

.hero__overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100%;
  background:
    linear-gradient(to bottom, rgba(255, 255, 255, 0.586) 0%, rgba(255, 255, 255, 0) 15%);
  pointer-events: none;
  z-index: 5;
}

  .hero__content {
    position: relative;
    z-index: 10;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 5% 10%;
    pointer-events: auto; 
  }

  .hero__title {
    font-family: var(--header-font-serif, serif);
    font-size: clamp(3rem, 8vw, 8rem);
    line-height: 1;
    color: var(--hero-text);
    margin: 0;
    text-align: right;
    letter-spacing: -1px; 
  }

  .hero__subtitle {
    font-family: var(--header-font-sans, sans-serif);
    font-size: clamp(0.9rem, 1rem, 1.1rem);  
    color: var(--hero-text);
    position: absolute;
    top: 50%;
    left: 10%;
    letter-spacing: -1px;
  }

  /* MEDIA QUERIES MOBILE */
  @media (max-width: 768px) {
    .track-small { height: 40vh; }
    .track-large { height: 50vh; }
    .hero__grid-wrapper { transform: translate(-50%, -50%) rotate(-20deg); } /* Suaviza a angulação em telas estreitas */
    .hero__subtitle { top: 20%; width: 80%; }
  }
</style>

<script>
  import gsap from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    let ctx = gsap.context(() => {
      
      const trackLeft = document.querySelectorAll('.track-left');
      const trackRight = document.querySelectorAll('.track-right');


      if (trackLeft.length) {
        gsap.to(trackLeft, {
          xPercent: -33.33,
          duration: 40, 
          ease: 'none',
          repeat: -1
        });
      }

      if (trackRight.length) {
        gsap.set(trackRight, { xPercent: -33.33 });
        gsap.to(trackRight, {
          xPercent: 0,
          duration: 40,
          ease: 'none',
          repeat: -1
        });
      }

    });
  });
</script>