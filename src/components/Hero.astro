---
// src/components/Hero.astro

import { client } from '../lib/prismic';


const optimizeImg = (url: string | undefined) => {
  if (!url) return '';
  const separator = url.includes('?') ? '&' : '?';
  return `${url}${separator}auto=format,compress&w=800&q=80`;
};


const [homeData, settingsData] = await Promise.all([
  client.getSingle('home').catch(() => null),
  client.getSingle('settings').catch(() => null),
]);



// Fallbacks completos para imagens (5 cada, para o efeito de esteira)
const defaultTopBot = [
  { src: '/imagens/ensaios/ensaios1.jpg', ratio: '3/4' },
  { src: '/imagens/ensaios/ensaios2.jpg', ratio: '3/4' },
  { src: '/imagens/ensaios/ensaios3.jpg', ratio: '3/4' },
  { src: '/imagens/ensaios/ensaios4.jpg', ratio: '3/4' },
  { src: '/imagens/ensaios/ensaios5.jpg', ratio: '3/4' },
];
const defaultMid = [
  { src: '/imagens/ensaios/ensaios6.jpg', ratio: '3/4' },
  { src: '/imagens/significados/momentos1.jpg', ratio: '3/4' },
  { src: '/imagens/significados/momentos2.jpg', ratio: '3/4' },
  { src: '/imagens/significados/momentos3.jpg', ratio: '3/4' },
  { src: '/imagens/significados/momentos4.jpg', ratio: '3/4' },
];


// Logo: prioriza 'logo_nome' do settings, fallback para o SVG local
const logoUrl = settingsData?.data.logo_nome?.url || '/logo-nome.svg';
const logoAlt = settingsData?.data.site_title || 'Carolina Alves';


// Subtítulo: do 'home', com fallback (quebra de linha com \n no Prismic)
const subtitle = homeData?.data?.hero_subtitle
  ? String(homeData.data.hero_subtitle)
  : 'Há 14 anos revelando a essência e a força feminina\nem Campo Grande. Um espaço de acolhimento para\nvocê se ver por inteiro e ressignificar sua história.';
  
// Imagens: extrai dos grupos do 'home', garante pelo menos 5 itens repetindo a última
let imagesTopBot = defaultTopBot;
let imagesMid = defaultMid;


const topBotPrismic = homeData?.data?.track_top_bot;
const midPrismic = homeData?.data?.track_mid;

if (topBotPrismic && topBotPrismic.length > 0) {
  const prismicTopBot = topBotPrismic.map((item: any) => ({
    src: optimizeImg(item.image?.url),
    ratio: '3/4',
  }));
  while (prismicTopBot.length < 5) {
    prismicTopBot.push({ ...prismicTopBot[prismicTopBot.length - 1] });
  }
  imagesTopBot = prismicTopBot.slice(0, 15); // triplica depois
}

if (midPrismic && midPrismic.length > 0) {
  const prismicMid = midPrismic.map((item: any) => ({
    src: optimizeImg(item.image?.url),
    ratio: '3/4',
  }));
  while (prismicMid.length < 5) {
    prismicMid.push({ ...prismicMid[prismicMid.length - 1] });
  }
  imagesMid = prismicMid.slice(0, 15);
}

const trackTopBot = [...imagesTopBot, ...imagesTopBot, ...imagesTopBot];
const trackMid = [...imagesMid, ...imagesMid, ...imagesMid];


---


<section class="hero section" id="hero">
  <div class="hero__grid-wrapper">
    
    <div class="hero__track track-left track-small">
      {trackTopBot.map((item, index) => (
        <div class="hero__item" style={`aspect-ratio: ${item.ratio};`}>
          <img
              src={item.src}
              alt=""
              loading={index < 2 ? "eager" : "lazy"}
              decoding="async" 
              draggable="false"
            />
        </div>
      ))}
    </div>

    <div class="hero__track track-right track-large">
      {trackMid.map((item, index) => (
        <div class="hero__item" style={`aspect-ratio: ${item.ratio};`}>
          <img
              src={item.src}
              alt=""
              loading={index < 2 ? "eager" : "lazy"}
              decoding="async" 
              draggable="false"
            />
        </div>
      ))}
    </div>

    <div class="hero__track track-left track-small">
      {trackTopBot.map((item, index) => (
        <div class="hero__item" style={`aspect-ratio: ${item.ratio};`}>
          <img
              src={item.src}
              alt=""
              loading={index < 2 ? "eager" : "lazy"}
              decoding="async" 
              draggable="false"
            />
        </div>
      ))}
    </div>

  </div>

  <div class="hero__overlay"></div>
  <div class="hero__content">
    <h1 class="hero__title">
      <img 
        src={logoUrl} 
        alt={logoAlt} 
        class="hero__title-svg"
      />
    </h1>
    <p class="hero__subtitle" style="white-space: pre-line;">{subtitle}</p>
  </div>
</section>


<style>



  .hero {
    position: sticky;
    top: 0;
    width: 100vw;
    height: 100dvh;
    overflow: hidden;
    background-color: var(--hero-bg);
    z-index: 1;
  }

  .next-section {
    position: relative;
    width: 100%;
    min-height: 100vh;
    background-color: #ffffff;
    z-index: 2; 
    padding: 100px 5%; 
  }

  .hero__grid-wrapper {
    position: absolute;
    top: 50%;
    left: 50%;
    
    transform: translate(-50%, -50%) rotate(-30deg);
    display: flex;
    flex-direction: column;
    gap: 2rem; /* Gap entre as faixas */
    width: 150vw; 
    justify-content: center;
    align-items: center;
  }

  .hero__track {
    display: flex;
    gap: 2rem; /* Gap entre as imagens */
    width: max-content; 
    will-change: transform;
  }

  /* Controle Assimétrico de Alturas */
  .track-small { height: 65vh; }
  .track-large { height: 80vh; }

  .hero__item {
    height: 100%; 
    background-color: rgba(255, 255, 255, 0.03);
    overflow: hidden;
  }

  .hero__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    opacity: 0.6;
    transition: opacity 0.4s ease;
    filter: grayscale(100%);
    user-drag: none;
    -webkit-user-drag: none;
    user-select: none;
    -webkit-user-select: none;
  }

  /* .hero__item:hover img {
    opacity: 1;
  } */

.hero__overlay {
  position: absolute;
  top: 0;
  left: 0;
  width: 100vw;
  height: 100%;
  background: radial-gradient(circle, rgba(8,13,11,0.5) 0%, rgba(8,13,11,0.5) 20%);

  pointer-events: none;
  z-index: 5;
}

  .hero__content {
    position: relative;
    z-index: 10;
    width: 100%;
    height: 100%;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    padding: 5% 10%;
    pointer-events: auto; 
  }

.hero__title {
  font-size: 0;          /* elimina espaço extra do inline-block */
  line-height: 0;
  margin: 0;
  text-align: right;
}

.hero__title-svg { 
  color: white;
  width: 100%;
  max-width: 600px;     
  height: auto;
  display: inline-block; /* permite alinhamento à direita */
}

  .hero__subtitle {
    font-size: clamp(0.9rem, 1rem, 1.1rem);  
    color: var(--color-text);
    position: absolute;
    top: 50%;
    left: 10%;
    letter-spacing: -1px;
    line-height: 1.3;
  }

  /* MEDIA QUERIES MOBILE */
  @media (max-width: 768px) {
    .track-small { height: 40vh; }
    .track-large { height: 50vh; }
    .hero__grid-wrapper { transform: translate(-50%, -50%) rotate(-20deg); } /* Suaviza a angulação em telas estreitas */
    .hero__subtitle {
    font-size: clamp(0.9rem, 2.5vw, 0.95rem);   /* ligeiramente menor que o desktop */
    width: 90%;                                   /* mais espaço horizontal */
    left: 5%;                                     /* centraliza compensando a largura */
    top: 40%;                                     /* mantém a posição vertical */
    line-height: 1.4;
  }
  }
    
</style>


<script>
  import gsap from 'gsap';

  document.addEventListener('DOMContentLoaded', () => {
    const trackLeft = document.querySelectorAll('.track-left');
    const trackRight = document.querySelectorAll('.track-right');

    // Movimento linear contínuo para a esquerda
    if (trackLeft.length > 0) {
      gsap.to(trackLeft, {
        xPercent: -33.33,
        duration: 40,
        ease: 'none',
        repeat: -1,
      });
    }

    // Movimento linear contínuo para a direita
    if (trackRight.length > 0) {
      gsap.set(trackRight, { xPercent: -33.33 });
      gsap.to(trackRight, {
        xPercent: 0,
        duration: 40,
        ease: 'none',
        repeat: -1,
      });
    }
    
  // Pausar tracks quando a Hero for totalmente coberta
    
    const hero = document.querySelector('#hero') as HTMLElement;
    const lenis = (window as any).lenisInstance;
    let tracksPaused = false;

      lenis.on('scroll', ({ scroll }: { scroll: number }) => {
        const heroHeight = hero.offsetHeight;
        const tweens = gsap.getTweensOf('.track-left, .track-right');

        if (scroll >= heroHeight) {
          if (!tracksPaused) {
            tracksPaused = true;
            tweens.forEach(t => t.pause());
          }
        } else {
          if (tracksPaused) {
            tracksPaused = false;
            tweens.forEach(t => t.resume());
          }
        }
      });
});
  

  
</script>