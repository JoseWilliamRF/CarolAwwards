---
// src/components/Historias.astro
import { client } from '../lib/prismic';

interface Depoimento {
  nome: string;
  papel: string;
  texto: string;
  fotoUrl: string;
}

const optimizeImg = (url: string | undefined) => {
  if (!url) return '';
  const separator = url.includes('?') ? '&' : '?';
  return `${url}${separator}auto=format,compress&w=800&q=80`;
};

const depoimentosDocs = await client.getAllByType('depoimento').catch(() => []);

let depoimentos: Depoimento[] = depoimentosDocs.map((doc: any) => {
  return {
    nome: doc.data.nome || 'Cliente',
    papel: doc.data.papel || 'Papel',
    texto: doc.data.texto || 'Depoimento não encontrado.',
    fotoUrl: optimizeImg(doc.data.foto?.url) || 'https://images.unsplash.com/photo-1516035069371-29a1b244cc32?q=80&w=800&auto=format&fit=crop'
  };
});

if (depoimentos.length === 0) {
  depoimentos = [
    { nome: "Carolina M.", papel: "Noiva", texto: "A Carol não entrega apenas fotos, ela entrega fragmentos da nossa alma. O cuidado em cada detalhe foi surreal.", fotoUrl: "https://images.unsplash.com/photo-1516035069371-29a1b244cc32?q=80&w=800&auto=format&fit=crop" },
    { nome: "Beatriz S.", papel: "Mãe", texto: "O ensaio gestante foi um resgate da minha autoestima. Me vi forte, linda e conectada com meu bebê.", fotoUrl: "https://images.unsplash.com/photo-1516035069371-29a1b244cc32?q=80&w=800&auto=format&fit=crop" },
    { nome: "Amanda L.", papel: "Empresária", texto: "A fotografia de posicionamento elevou minha marca. Profissionalismo e um olhar clínico impecável.", fotoUrl: "https://images.unsplash.com/photo-1516035069371-29a1b244cc32?q=80&w=800&auto=format&fit=crop" }
  ];
}
---

<section class="historia section" id="historias">
  <div class="historia__container">
    
    <h2 class="historia__title">Histórias</h2>
      
    <div class="historia__cards-wrapper">
      {depoimentos.map((dep) => (
        <article class="depoimento-card">
          
          <div class="depoimento__foto-wrapper">
            <img 
              src={dep.fotoUrl} 
              alt={`Foto cliente ${dep.nome}`} 
              loading="lazy" 
              decoding="async" 
              class="depoimento__foto" 
            />
          </div>

          <div class="depoimento__content">
            <header class="depoimento__header">
              <div>
                <h3 class="depoimento__nome">{dep.nome}</h3>
                <span class="depoimento__papel">{dep.papel}</span>
              </div>
              <div class="depoimento__badge">
                <svg viewBox="0 0 24 24" fill="currentColor"><path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-2 15l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/></svg>
                Depoimento
              </div>
            </header>
            <p class="depoimento__texto">"{dep.texto}"</p>

            <div class="depoimento__stars">
              {"★★★★★".split('').map(star => <span>{star}</span>)}
            </div>
          </div>

        </article>
      ))}
    </div>

    <div class="historia__blank-space"></div>

  </div>
</section>

<style>
  .historia {
    position: relative;
    z-index: 4;
    width: 100vw;
    min-height: 100dvh;
    
    overflow: hidden;
  }

  .historia__container {
    display: grid;
    grid-template-columns: 95% 5%;
    width: 100%;
    max-width: 1600px;
    margin: 0 auto;
    padding: 0 5%;
    gap: 1.5rem;
  }

  .historia__title {
    grid-column: 1 / -1;
    font-size: clamp(2rem, 3vw, 3rem);
    color: var(--color-text, #F4F4F4);
    text-transform: uppercase;
    font-weight: 500;
    letter-spacing: 0.05em;
    padding-top: 85px;
    margin-bottom: 0;
    text-align: center;
  }

  .historia__cards-wrapper {
    position: relative;
    width: 100%;
    min-height: 75vh;
  }

  .depoimento-card {
    position: absolute;
    width: 100%;
    max-width: 380px;
    display: flex;
    flex-direction: column;
  }

  .depoimento-card:nth-child(1) { top: -2%;  left: 0; }
  .depoimento-card:nth-child(2) { top: 12%;  left: 48%; }
  .depoimento-card:nth-child(3) { top: 51%;  left: 22%; }

  .depoimento__foto-wrapper {
    width: 90%;
    aspect-ratio: 2 / 1;
    overflow: hidden;
    position: relative;
  }

  .depoimento__foto {
    width: 100%;
    height: 100%;
    object-fit: cover;
    filter: grayscale(100%);
    transition: filter 0.4s ease, transform 0.8s ease;
  }

  .depoimento-card:hover .depoimento__foto {
    filter: grayscale(0%);
    transform: scale(1.03);
  }

  .depoimento__content {
    position: relative;
    z-index: 4;
    background-color: #FDFDFD;
    color: var(--color-overlay, #0D0D0D);
    padding: 1.5rem 2rem;
    width: 90%;
    align-self: flex-end;
    margin-top: -4rem;
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.08);
  }

  .depoimento__header {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    margin-bottom: 1rem;
  }

  .depoimento__nome {
    font-family: var(--font-sans);
    font-size: 1rem;
    font-weight: 600;
  }

  .depoimento__papel {
    font-family: var(--font-sans);
    font-size: 0.75rem;
    opacity: 0.6;
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .depoimento__badge {
    display: flex;
    align-items: center;
    gap: 0.5rem;
    font-size: 0.75rem;
    font-weight: 600;
    color: #4A4A4A;
  }

  .depoimento__badge svg {
    width: 16px;
    height: 16px;
    color: #080D0B;
  }

  .depoimento__texto {
    font-size: 0.85rem;
    line-height: 1.5;
    color: #222;
  }

  .depoimento__stars {
    position: absolute;
    bottom: -15px;
    left: 20px;
    background-color: #080D0B;
    color: #FFF;
    padding: 0.5rem 1rem;
    display: flex;
    gap: 0.2rem;
    font-size: 0.8rem;
    z-index: 3;
  }

  @media (max-width: 1024px) {
    .historia__container {
      grid-template-columns: 1fr;
    }
    .historia__title {
      padding-top: 6rem;
    }
    .historia__cards-wrapper {
      min-height: auto;
    }
    .depoimento-card {
      position: relative !important;
      top: auto !important;
      left: auto !important;
      max-width: 90% !important;
      margin: 0 auto 3rem;
    }
    .depoimento__content {
      width: 95%;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    const cards = document.querySelectorAll('.depoimento-card');

    cards.forEach((card) => {



      const isMobile = window.innerWidth <= 768;

      gsap.set(card, { y: 80, x: 30, opacity: 0, rotation: 4 });
      gsap.to(card, {
        y: 0, x: 0, opacity: 1, rotation: 0,
        duration: isMobile ? 0.3 : 0.5,
        ease: 'sine.inOut',
        scrollTrigger: { trigger: card, start: 'top 95%', toggleActions: 'play none none reverse' },
      });
      

    });
  });
</script>