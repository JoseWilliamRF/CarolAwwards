        ))}
      </div>

      <a href="https://wa.me/5567992890225?text=Vim%20pelo%20site!%20Gostaria%20de%20saber%20mais%20sobre%20os%20pacotes" class="pacotes__btn" target="_blank" rel="noopener noreferrer" id="pacotes-btn">
        <svg viewBox="0 0 24 24" fill="currentColor" width="20" height="20" class="btn-icon">
          <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 0 1-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 0 1-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 0 1 2.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0 0 12.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 0 0 5.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 0 0-3.48-8.413z"/>
        </svg>
        <span class="btn-text">RESERVAR MOMENTO</span>
      </a>
    </div>

  </div>
  <style>
  /* 1. O FUNDO PURO (Sem película escura) */
  .pacotes {
    position: relative; 
    z-index: 2;        
    width: 100vw;
    min-height: 100dvh; 
    
    display: flex;
    align-items: center;
    overflow: hidden;
  }

  .pacotes__container {
    width: 100%;
    max-width: 1600px; /* Ajuste conforme a largura máxima desejada para o conteúdo */
    margin: 0 auto;
    padding: 10vh 5%;
    
    display: grid;
    grid-template-columns: 2fr 1fr; /* 2 partes para conteúdo, 1 parte para o espaço da modelo */
    gap: 4rem;
  }

  /* 3. A ÁREA DE CONTEÚDO (Esquerda) */
  .pacotes__content {
    display: flex;
    flex-direction: column;
    align-items: center; 
    gap: 1.5rem 3rem;
  }

  .pacotes__title {
    font-size: clamp(2rem, 3vw, 3rem);
    color: var(--pacotes-text-color, #0D0D0D);
    text-transform: uppercase;
    font-weight: 500;
    letter-spacing: 0.05em;
    margin-top: 3rem
  }

  /* 4. A GRELHA DOS PACOTES (Os 3 quadros alinhados) */
  .pacotes__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 2rem;
    width: 100%;
  }

  .pacotes__item {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 1rem;
  }

  .pacotes__label {
    color: var(--pacotes-text-color, #0D0D0D);
    font-size: 1rem;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    opacity: 0.9;
    transition: opacity 0.3s ease;
  }

  .pacotes__label:hover {
    opacity: 1;
  }

  /* 5. O BOTÃO WHATSAPP — Glassmorphism */
  .pacotes__btn {
    padding: 1rem 2rem;
    border: none;
    color: var(--pacotes-text-color, #0D0D0D);
    font-size: 0.85rem;
    text-decoration: none;
    font-weight: 500;
    text-transform: uppercase;
    letter-spacing: 0.05em;
    cursor: pointer;
    user-select: none;
    transition: all 0.3s ease;
    
    align-self: flex-start; 
    margin-left: 2%;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 0.5rem;

    background: linear-gradient(180deg, rgba(255, 255, 255, 0.06) 0%, rgba(255, 255, 255, 0.02) 40%, rgba(255, 255, 255, 0.04) 100%);
    backdrop-filter: blur(4px) saturate(140%) brightness(1.02);
    -webkit-backdrop-filter: blur(4px) saturate(140%) brightness(1.02);
    box-shadow: 0 0 0 1px rgba(244, 244, 244, 0.15), inset 0 1px 0 rgba(255, 255, 255, 0.08);
    border-radius: 4px;
  }

  .pacotes__btn:hover {
    transform: scale(1.02);
    background: #ffffff;
    color: #080D0B;
  }

  .btn-icon {
    flex-shrink: 0;
  }

  .card {
    height: 379px;
    width: 100%;
    max-width: 300px;
    background-color: black;
    border-radius: 10px;
    overflow: hidden;
    display: flex;
    justify-content: center;
    align-items: center;
    position: relative;
    box-shadow: 0 70px 63px -60px #000000;
    margin: 0 auto;
    cursor: pointer;
  }
  
  .card__img {
    position: absolute;
    top: 0;
    left: 0;
    width: 100%;
    height: 100%;
    object-fit: cover;
    transform-origin: left center; 
    transition: opacity 0.6s ease, transform 0.8s ease;
  }

  .card__img--next {
    opacity: 0;
    pointer-events: none;
  }

  .card:hover .card__img {
   transform: scale(1.3) translateX(-10px);
    object-position: left center;
  }

  .pacotes__grid.has-interaction .card {
    opacity: 0.7;
    filter: grayscale(100%);
    transform: scale(0.98);
    transition: opacity 0.4s ease, filter 0.4s ease, transform 0.4s ease;
  }

  .pacotes__grid.has-interaction .card.is-focused {
    opacity: 1;
    filter: grayscale(0%);
    transform: scale(1.05);
    border: 1px solid white;
  }

  .pacotes__grid.has-interaction .card.is-focused .card__inner-title,
  .pacotes__grid.has-interaction .card.is-focused .card__icons {
    opacity: 1;
  }

  .card__border {
    position: absolute;
    inset: 5px; 
    background: transparent;
    border-radius: 10px;
    transition: border 1s;
    display: flex;
    flex-direction: column;
    align-items: center;
    z-index: 2;
  }

  .card:hover .card__border {
    border: 1px solid white;
  }

  .card__inner-title {
    font-family: var(--font-sans);
    color: white;
    margin: 20px;
    opacity: 0;
    transition: opacity 1s;
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .card__icons {
    position: absolute;
    left: 1px;
    fill: #fff;
    color: #fff;
    height: 130px;
    top: 226px;
    width: 50px;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: space-around;
    opacity: 0;
    transition: opacity 1s;
  }

  .card__icon {
    width: 22px;
    height: 22px;
  }

  .card__icon-link {
    display: flex;
    color: inherit;
    transition: opacity 0.3s ease;
  }

  .card__icon-link:hover {
    opacity: 0.7;
  }

  /* SETAS DE NAVEGAÇÃO */
  .card__arrow {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 24px;
    height: 24px;
    background: none;
    border: none;
    color: #fff;
    opacity: 0.25;
    transition: opacity 0.3s ease;
    cursor: pointer;
    padding: 0;
    display: flex;
    align-items: center;
    justify-content: center;
  }

  .card__arrow svg {
    width: 100%;
    height: 100%;
  }

  .card__arrow--left  { left: 8px; }
  .card__arrow--right { right: 8px; }

  .card:hover .card__arrow {
    opacity: 1;
  }

  .card:hover .card__inner-title,
  .card:hover .card__icons {
    opacity: 1;
  }

  /* MOBILE: setas maiores + ícones sempre visíveis */
  @media (max-width: 768px), (hover: none) {
    .card__arrow {
      width: 44px;
      height: 44px;
      opacity: 0.45;
    }
    .card__arrow--left  { left: 4px; }
    .card__arrow--right { right: 4px; }
    .card__icons {
      opacity: 0.85;
    }
  }
  /* 7. MEDIA QUERIES (Responsividade) */
  @media (max-width: 1024px) {
    .pacotes__container {
      grid-template-columns: 1fr; 
      padding: 15vh 10%;
    }
  }

  @media (max-width: 768px) {
    
  .pacotes__title {
    margin-top: 1rem;}
    
    .pacotes__grid {
      grid-template-columns: 1fr; /* Empilha os quadros */
    }
    .card {
      max-width: 350px; 
      margin: 0 auto;
    }
    .pacotes__btn {
      align-self: center; /* Centraliza o botão no celular */
      margin-left: 0;
    }
  }
</style>

<script>
  import gsap from 'gsap';
  import { ScrollTrigger } from 'gsap/ScrollTrigger';

  gsap.registerPlugin(ScrollTrigger);

  document.addEventListener('DOMContentLoaded', () => {
    const grid = document.querySelector('.pacotes__grid');
    const items = gsap.utils.toArray('.pacotes__item');

    if (!grid || items.length === 0) return;

    ScrollTrigger.getAll()
      .filter(st => st.trigger === grid || st.vars.trigger === grid)
      .forEach(st => st.kill());

    const ease = 'cubic-bezier(0.19, 1, 0.22, 1)';

    console.log('%c[PACOTES] ease: ' + ease, 'color: #00ff88;');

    gsap.from(items, {
      x: -250,
      scale: 0.88,
      opacity: 0,
      duration: 1.5,
      stagger: {
        each: 0.8,
        from: 'start',
      },
      ease,
      scrollTrigger: {
        trigger: grid,
        start: 'top 82%',
        end: 'top 30%',
        scrub: 1,
      },
    });
    
    // ============================================
    // STATE MANAGER — Lock (click) ≠ Preview (hover)
    // ============================================
    const btn = document.getElementById('pacotes-btn') as HTMLAnchorElement | null;
    const btnText = btn?.querySelector('.btn-text') as HTMLElement | null;
    const allCards = document.querySelectorAll('.card');
    const defaultBtnText = 'RESERVAR MOMENTO';
    const defaultZapLink = 'https://wa.me/5567992890225?text=Vim%20pelo%20site!%20Gostaria%20de%20saber%20mais%20sobre%20os%20pacotes';
    let lockedCard: Element | null = null;

    const updateButton = (card: Element | null) => {
      if (!btn || !btnText) return;
      if (!card) {
        btnText.textContent = defaultBtnText;
        btn.href = defaultZapLink;
        return;
      }
      const category = (card as HTMLElement).dataset.category || 'MOMENTO';
      btnText.textContent = 'RESERVAR ' + category.toUpperCase();
      btn.href = 'https://wa.me/5567992890225?text=' + encodeURIComponent('Olá! Vim pelo Site, gostaria de saber mais sobre ' + category);
    };

    const renderVisualState = (hoveredCard: Element | null) => {
      const targetCard = hoveredCard || lockedCard;
      allCards.forEach(c => c.classList.remove('is-focused'));
      if (targetCard) {
        grid.classList.add('has-interaction');
        targetCard.classList.add('is-focused');
        updateButton(targetCard);
      } else {
        grid.classList.remove('has-interaction');
        updateButton(null);
      }
    };

    if (allCards.length > 0 && btn) {
      allCards.forEach(card => {
        card.addEventListener('mouseenter', () => renderVisualState(card));
        card.addEventListener('mouseleave', () => renderVisualState(null));
        card.addEventListener('click', () => {
          lockedCard = card;
          renderVisualState(card);
        });
      });
    }

    // ============================================
    // CARROSSEL — crossfade CSS puro
    // ============================================
    document.querySelectorAll('.card').forEach(card => {
      const imgs = card.querySelectorAll('.card__img');
      let imgActive = imgs[0] as HTMLImageElement;
      let imgNext   = imgs[1] as HTMLImageElement;
      const btnLeft = card.querySelector('.card__arrow--left') as HTMLElement | null;
      const btnRight = card.querySelector('.card__arrow--right') as HTMLElement | null;

      if (!btnLeft || !btnRight) return;

      const gallery: { src: string; alt: string }[] = JSON.parse(
        card.getAttribute('data-card-gallery') || '[]'
      );
      if (gallery.length <= 1) {
        btnLeft.style.display = 'none';
        btnRight.style.display = 'none';
        return;
      }

      const preloadAdjacent = (idx: number) => {
        const next = (idx + 1) % gallery.length;
        const prev = (idx - 1 + gallery.length) % gallery.length;
        new Image().src = gallery[next].src;
        new Image().src = gallery[prev].src;
      };
      preloadAdjacent(0);

      const slide = (dir: number) => {
        let idx = parseInt(card.getAttribute('data-card-index') || '0') + dir;
        if (idx < 0) idx = gallery.length - 1;
        if (idx >= gallery.length) idx = 0;
        card.setAttribute('data-card-index', String(idx));
        const swap = () => {
          imgActive.style.opacity = '0';
          imgNext.style.opacity = '1';
          const temp = imgActive;
          imgActive = imgNext;
          imgNext = temp;
          imgNext.classList.add('card__img--next');
          imgActive.classList.remove('card__img--next');
          preloadAdjacent(idx);
        };
        imgNext.onload = () => { imgNext.onload = null; swap(); };
        imgNext.src = gallery[idx].src;
        imgNext.alt = gallery[idx].alt;
        if (imgNext.complete) { imgNext.onload = null; swap(); }
      };

      btnLeft.addEventListener('click', (e) => { e.stopPropagation(); slide(-1); });
      btnRight.addEventListener('click', (e) => { e.stopPropagation(); slide(1); });
    });
  });
</script>