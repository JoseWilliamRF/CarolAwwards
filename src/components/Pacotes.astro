---
// src/components/Pacotes.astro
import { client } from '../lib/prismic';

const optimizeImg = (url: string | undefined) => {
  if (!url) return '';
  const separator = url.includes('?') ? '&' : '?';
  return `${url}${separator}auto=format,compress&w=600&q=80`;
};

// 1. O CONTRATO DE TIPAGEM (Strict Mode)
interface Pacote {
  images: { src: string; alt: string }[];
  title: string;
}

// 2. A MUDANÇA ARQUITETURAL: Buscar múltiplos documentos do tipo 'portifolio'
// NOTA: Se o API ID do teu custom type não for exatamente 'portifolio', altera aqui.
const portifolioDocs = await client.getAllByType('portfolio').catch(() => []);

// 3. MAPEAR OS DOCUMENTOS PARA OS CARDS (todas as imagens)
const pacotesList: Pacote[] = portifolioDocs.slice(0, 3).map((doc: any) => {
  const images = (doc.data.images || []).map((img: any) => ({
    src: optimizeImg(img.gallery_image?.url) || 'https://images.unsplash.com/photo-1516035069371-29a1b244cc32?q=80&w=600&auto=format&fit=crop',
    alt: img.gallery_image?.alt || doc.data.category_title || 'Imagem de portfólio',
  }));
  
  return {
    images: images.length > 0 ? images : [{ 
      src: 'https://images.unsplash.com/photo-1516035069371-29a1b244cc32?q=80&w=600&auto=format&fit=crop', 
      alt: 'Placeholder' 
    }],
    title: doc.data.category_title || `Pacote`, 
  };
});

// 4. FALLBACK DE SEGURANÇA
while (pacotesList.length < 3) {
  pacotesList.push({ 
    images: [{ src: 'https://images.unsplash.com/photo-1516035069371-29a1b244cc32?q=80&w=600&auto=format&fit=crop', alt: 'Em breve' }],
    title: 'Em breve' 
  });
}
---

