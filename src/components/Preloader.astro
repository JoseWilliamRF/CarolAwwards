---

import { client } from '../lib/prismic';


//otimização Imgix

const optimizeImg = (url: string | undefined) => {
  if (!url) return '';
  const separator = url.includes('?') ? '&' : '?';
  return `${url}${separator}auto=format,compress&w=800&q=80`;
};



const [preloaderData, settingsData] = await Promise.all([
  client.getSingle('preloader').catch(() => null),
  client.getSingle('settings').catch(() => null),
]);
// Fallbacks estáticos (imagens originais)
const defaultLeft = [
  '/imagens/ensaios/ensaios1.jpg',
  '/imagens/ensaios/ensaios2.jpg',
  '/imagens/ensaios/ensaios3.jpg',
  '/imagens/ensaios/ensaios4.jpg',
];
const defaultRight = [
  '/imagens/ensaios/ensaios5.jpg',
  '/imagens/ensaios/ensaios6.jpg',
  '/imagens/significados/momentos1.jpg',
  '/imagens/significados/momentos2.jpg',
];



// Logo: prioriza a 'custom_logo' do preloader, depois a global do settings, depois o SVG local
const logoUrl = preloaderData?.data.custom_logo?.url
  || settingsData?.data.logo_nome?.url
  || '/logo-nome.svg';
const logoAlt = settingsData?.data.site_title || 'Carolina Alves';



// Imagens das tracks (com fallback)
let leftImages = defaultLeft;
let rightImages = defaultRight;

const leftPrismic = preloaderData?.data?.left_track;
const rightPrismic = preloaderData?.data?.right_track;



if (leftPrismic && leftPrismic.length > 0) {
leftImages = leftPrismic.map((item: any) => optimizeImg(item.image?.url)).filter(Boolean);
  while (leftImages.length < 4) {
    leftImages.push(leftImages[leftImages.length - 1]); 
  }
  leftImages = leftImages.slice(0, 4); 
}
if (rightPrismic && rightPrismic.length > 0) {
  rightImages = rightPrismic.map((item: any) => optimizeImg(item.image?.url)).filter(Boolean);
  while (rightImages.length < 4) {
    rightImages.push(rightImages[rightImages.length - 1]);
  }
  rightImages = rightImages.slice(0, 4);
}

---

<div id="preloader" class="preloader">
  <div class="preloader__glass preloader__glass--left"></div>
  <div class="preloader__glass preloader__glass--right"></div>
  
  <div class="preloader__track preloader__track--left">
    {leftImages.map((src) => (
      <div class="preloader__slide">
        <img src={src} alt="" loading="eager" fetchpriority="high" />
      </div>
    ))}
  </div>

  <div class="preloader__track preloader__track--right">
    {rightImages.map((src) => (<div class="preloader__slide">
        <img src={src} alt="" loading="eager" fetchpriority="high" />
      </div>
    ))}
  </div>

  <div class="preloader__logo">
    <img src={logoUrl} alt={logoAlt} />
  </div>
  
  <!-- <div id="preloader-counter" class="preloader__counter">0%</div> -->
</div>

<style>
  .preloader__track {
  position: absolute;
  top: 0;
  width: 50%;
  height: 100dvh;
  will-change: transform;
}
.preloader__track--left { left: 0; }
.preloader__track--right { right: 0; }

.preloader__slide {
    position: absolute;
    width: 100%;
    height: 100dvh;
    overflow: hidden; 
    background: linear-gradient(
      135deg,
      #1a1a1a 0%,
      #3d3d3d 20%,
      #6b6b6b 40%,
      #8c8c8c 55%,
      #6b6b6b 70%,
      #3d3d3d 85%,
      #1a1a1a 100%
    );
    background-size: 300% 300%;
    animation: gradientShift 4s ease-in-out infinite alternate;
  }

.preloader__slide img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  opacity: 0.4;
  filter: grayscale(100%);
  will-change: transform;
  transform: scale(1.1); 
}

.preloader__counter {
  position: absolute;
  bottom: 5vh;
  left: 50%;
  transform: translateX(-50%);
  z-index: 20;
  color: var(--c-beige-background, #f5e8d1);
  font-size: 1rem;
  font-weight: 500;
  letter-spacing: 0.1em;
  font-variant-numeric: tabular-nums;
}

@media (max-width: 768px) {
  .preloader__track--right {
    display: none !important;
  }
  .preloader__track--left {
    width: 100% !important;
  }
}
  
</style>


<script>
  const DEBUG = false;
  let introSeen = false;

  // ==========================================================================
  // 1. BLINDAGEM DE SESSÃO
  // ==========================================================================
  try {
    introSeen = sessionStorage.getItem('introSeen') === 'true';
  } catch (e) {
    introSeen = false;
  }

  if (!introSeen || DEBUG) {
    try {
      sessionStorage.setItem('introSeen', 'true');
    } catch (e) {}

    const preloader = document.getElementById('preloader');
    
    if (preloader) {
      document.documentElement.style.overflow = 'hidden';

      // ==========================================================================
      // 2. CONFIGURAÇÕES E VARIÁVEIS GLOBAIS
      // ==========================================================================
      const leftTrack = preloader.querySelector('.preloader__track--left') as HTMLElement;
      const rightTrack = preloader.querySelector('.preloader__track--right') as HTMLElement;
      const glassLeft = preloader.querySelector('.preloader__glass--left') as HTMLElement | null;
      const glassRight = preloader.querySelector('.preloader__glass--right') as HTMLElement | null;
      const counterEl = document.getElementById('preloader-counter') as HTMLElement | null;
      const leftSlides = Array.from(leftTrack.querySelectorAll('.preloader__slide')) as HTMLElement[];
      const rightSlides = Array.from(rightTrack.querySelectorAll('.preloader__slide')) as HTMLElement[];

      const slideCount = Math.max(leftSlides.length, rightSlides.length);
      const maxOffset = Math.max((slideCount - 1) * 100, 0);
      const glassMaxOffset = 100;
      const PARALLAX_FACTOR = 1;

      // Tempos e Motores
      const START_DELAY = 600;
      const LERP = 0.08;
      const CLAMPED_STEP = 0.0025; // Define o tempo base de translação
      const EASE_STYLE = 'cubic';
      
      // Controle de Retenção (Hang Time)
      const HANG_TIME_MS = 250; // Tempo de tela congelada por foto
      let lastHangTimestamp = 0;
      let isHanging = false;
      let isExiting = false;

      // Estado da Linha do Tempo
      let phase = 0;            
      let phaseProgress = 0;    
      let delayElapsed = false;
      let networkProgress = 0;
      let rafId: number;

      // Configuração Espacial Inicial
      leftSlides.forEach((slide, i) => slide.style.top = `${i * 100}dvh`);
      rightSlides.forEach((slide, i) => slide.style.top = `${-i * 100}dvh`);

      // ==========================================================================
      // 3. MOTOR FÍSICO (EASING)
      // ==========================================================================
      const getEaseInOut = (t: number, style: string) => {
        if (style === 'cubic') {
          return t < 0.5 
            ? 4 * t * t * t 
            : 1 - Math.pow(-2 * t + 2, 3) / 2;
        }
        if (style === 'expo') {
          if (t === 0) return 0;
          if (t === 1) return 1;
          return t < 0.5 
            ? Math.pow(2, 20 * t - 10) / 2 
            : (2 - Math.pow(2, -20 * t + 10)) / 2;
        }
        return t; 
      };

      // ==========================================================================
      // 4. RASTREADOR DE REDE (NETWORK TRACKER)
      // ==========================================================================
      const safetyTimeout = setTimeout(() => {
        if (networkProgress < 1) networkProgress = 1;
      }, 15000);

      const initNetworkTracker = () => {
        const images = Array.from(leftTrack.querySelectorAll('img'));
        const totalImages = images.length;
        let loadedCount = 0;

        if (totalImages === 0) {
          networkProgress = 1;
        } else {
          images.forEach(img => {
            if (img.complete) {
              loadedCount++;
              networkProgress = loadedCount / totalImages;
            } else {
              img.addEventListener('load', () => {
                loadedCount++;
                networkProgress = loadedCount / totalImages;
              });
              img.addEventListener('error', () => {
                loadedCount++;
                networkProgress = loadedCount / totalImages; 
              });
            }
          });
        }
      };
      
      initNetworkTracker();

      const delayTimeout = setTimeout(() => {
        delayElapsed = true;
        initNetworkTracker(); 
      }, START_DELAY);


      // ==========================================================================
      // 5. LOOP DE RENDERIZAÇÃO DOM (60FPS)
      // ==========================================================================
      const render = (timestamp: number) => {
        
        // --- 5.1. Atualização do Contador ---
        if (counterEl) {
          const globalPercent = phase === 0 
            ? phaseProgress * 50 
            : 50 + (phaseProgress * 50);
          counterEl.innerText = `${Math.min(Math.round(globalPercent), 100)}%`;
        }
        
        if (!delayElapsed) {
          rafId = requestAnimationFrame(render);
          return;
        }

        // --- 5.2. Relógio de Liberação (Hang Time) ---
        if (isHanging) {
          if (timestamp - lastHangTimestamp >= HANG_TIME_MS) {
            isHanging = false; 
          }
        }
        
        // --- 5.3. Avanço Quantizado de Tempo ---
        const speedMultiplier = phase === 0 ? Math.max((maxOffset / 100), 1) : 1;
        const currentLerp = LERP * speedMultiplier;
        const currentClamp = CLAMPED_STEP * speedMultiplier;

        const distance = networkProgress - phaseProgress; 
        const baseStep = distance * currentLerp;
        const step = Math.min(baseStep, currentClamp);
        
        if (step > 0 && !isHanging) {
          const steps = slideCount - 1; 
          const previousProgress = phaseProgress; 
          
          phaseProgress = Math.min(phaseProgress + step, 1);

          if (phase === 1) {
            const previousStep = Math.floor(previousProgress * steps);
            const newStep = Math.floor(phaseProgress * steps);

            if (newStep > previousStep && phaseProgress < 1) {
              phaseProgress = newStep / steps; 
              isHanging = true;                
              lastHangTimestamp = timestamp;   
            }
          }
        }

        // ==========================================================================
        // 6. CÁLCULO E APLICAÇÃO DE TRANSFORM (CSS)
        // ==========================================================================
        
        // --- FASE 0: VIDRO ---
        if (phase === 0) {
          const eased = getEaseInOut(phaseProgress, EASE_STYLE)
          const offset = eased * glassMaxOffset;   
          
          if (glassLeft) glassLeft.style.transform = `translateY(-${offset}dvh)`;
          if (glassRight) glassRight.style.transform = `translateY(${offset}dvh)`;

          if (phaseProgress > 0.999) phaseProgress = 1;

          if (phaseProgress >= 1) {
            phase = 1;
            phaseProgress = 0; 
            
            isHanging = true;                
            lastHangTimestamp = timestamp;
          }
        }

        // --- FASE 1: ESTEIRA DE IMAGENS ---
        else if (phase === 1) {
          const steps = slideCount - 1; 
          const steppedProgress = phaseProgress * steps;
          const currentStep = Math.floor(steppedProgress);
          let fraction = steppedProgress - currentStep;

          const easedFraction = getEaseInOut(fraction, EASE_STYLE);
          const finalEasing = phaseProgress >= 1 ? 0 : easedFraction;
          const offset = (currentStep + finalEasing) * 100;

          leftTrack.style.transform = `translateY(-${offset}dvh)`;
          rightTrack.style.transform = `translateY(${offset}dvh)`;

          leftSlides.forEach((slide, i) => {
            const absoluteY = (i * 100) - offset;
            const img = slide.querySelector('img') as HTMLElement;
            img.style.transform = `translateY(${-absoluteY * PARALLAX_FACTOR}dvh) scale(1.1)`;
          });
          
          rightSlides.forEach((slide, i) => {
            const absoluteY = (-i * 100) + offset;
            const img = slide.querySelector('img') as HTMLElement;
            img.style.transform = `translateY(${-absoluteY * PARALLAX_FACTOR}dvh) scale(1.1)`;
          });
            
          if (phaseProgress > 0.999) phaseProgress = 1;
          
          // --- FASE 2: SAÍDA ---
          if (phaseProgress >= 1 && networkProgress >= 1) {
            
            if (!isExiting) {
              isExiting = true;
              
              setTimeout(() => { 
                phase = 2;
                leftTrack.style.transform = `translateY(-${maxOffset}dvh)`;
                rightTrack.style.transform = `translateY(${maxOffset}dvh)`;
                if (glassLeft) glassLeft.style.transform = `translateY(-${glassMaxOffset}dvh)`;
                if (glassRight) glassRight.style.transform = `translateY(${glassMaxOffset}dvh)`;

                if (!DEBUG) {
                  preloader.style.setProperty('--progress', '1');
                  document.documentElement.classList.add('is-preloader-disabled');
                  
                  let isRemoved = false;
                  const removePreloader = () => {
                    if (isRemoved) return;
                    isRemoved = true;
                    clearTimeout(safetyTimeout);
                    clearTimeout(delayTimeout);
                    preloader.remove();
                    document.documentElement.style.overflow = '';
                    window.dispatchEvent(new Event('preloaderComplete'));
                  };
                  
                  preloader.addEventListener('transitionend', removePreloader, { once: true });
                  setTimeout(removePreloader, 1500);
                }
                
                cancelAnimationFrame(rafId);
              }, 250); // Hang time da última foto
            }
            
            rafId = requestAnimationFrame(render);
            return;
          }
        }

        rafId = requestAnimationFrame(render);
      };

      // Inicia o motor
      rafId = requestAnimationFrame(render);
    }
  } else {
    // Fallback: Preloader já visto
    document.getElementById('preloader')?.remove();
    document.documentElement.classList.add('is-preloader-disabled');
    requestAnimationFrame(() => window.dispatchEvent(new Event('preloaderComplete')));
  }
</script>