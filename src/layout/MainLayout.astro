---
// src/layout/MainLayout.astro
import Preloader from '../components/Preloader.astro';

import { client } from '../lib/prismic'; 

// Busca o Singleton 'settings'
let settings;
try {
  settings = await client.getSingle('settings');
} catch (error) {
  console.error("Erro ao buscar 'settings' no Prismic:", error);
}

// Definição de Props com Fallback para o CMS
interface Props {
  title?: string;
  description?: string;
}

//Mapeamento estrito dos API ID
const { 
  title = settings?.data.site_title as string || "Portfólio Carolina Alves", 
  description = settings?.data.site_description as string || "Fotografia e Design"
} = Astro.props;

// Extração do Logo Global para uso futuro (Header/Footer)
const globalLogo = settings?.data.logo?.url;
const ogImage = settings?.data.og_image?.url;

---

<!DOCTYPE html>
<html lang="pt-BR">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />
    
    <!-- SEO Dinâmico -->
    <meta name="description" content={description} />
    <title>{title}</title>
    
    
    
  <!-- Open Graph / Redes Sociais -->
  <meta property="og:title" content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:image" content={ogImage ?? '/logo-nome.svg'} />
  <meta property="og:type" content="website" />
  <meta property="og:locale" content="pt_BR" />
  <meta property="og:site_name" content="Carolina Alves Fotografia" />

    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Montserrat:wght@400;500&family=Playfair+Display:wght@400;600&display=swap"
      rel="stylesheet"
    />

    <link rel="icon" type="image/png" href="/favicon-96x96.png" sizes="96x96" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="shortcut icon" href="/favicon.ico" />
    <link rel="apple-touch-icon" sizes="180x180" href="/apple-touch-icon.png" />
    <link rel="manifest" href="/site.webmanifest" />
    <style is:inline>
      html {
        background: url('/foto-background.jpg') center/cover fixed no-repeat #080D0B;
      }
      body { 
        background-color: transparent; 
        margin: 0; 
      }
      
      .preloader {
        position: fixed;
        inset: 0;
        z-index: 10000;
        background-color: var(--color-overlay, #080D0B);
        display: flex;
        touch-action: none;
        transition: opacity 0.8s ease-out;
        will-change: opacity;
      }

      html.is-preloader-disabled .preloader {
        opacity: 0;
        pointer-events: none;
      }

      /* ========================================================== */
      /* MOTORES DE ANIMAÇÃO                                        */
      /* ========================================================== */
      @keyframes glassBreathe {
        0%, 100% { 
          background: rgba(255, 255, 255, 0.02); 
          backdrop-filter: blur(15px); 
        }
        50% { 
          background: rgba(255, 255, 255, 0.06); 
          backdrop-filter: blur(25px); 
        }
      }
      
      @keyframes logoPulse {
        0%, 100% { opacity: 0.6; transform: scale(0.98); }
        50% { opacity: 1; transform: scale(1.02); }
      }

      /* Motor do Skeleton Cromado */
      @keyframes gradientShift {
        0% { background-position: 0% 0%; }
        100% { background-position: 100% 100%; }
      }

      /* ========================================================== */
      /* ESTRUTURAS VISUAIS DO FRAME ZERO                           */
      /* ========================================================== */
      
      /* O Skeleton: Fundo dinâmico que mascara o atraso de rede */
      .preloader__slide {
        position: absolute;
        width: 100%;
        height: 100dvh;
        overflow: hidden; 
        background: linear-gradient(
          135deg,
          #1a1a1a 0%,
          #3d3d3d 20%,
          #6b6b6b 40%,
          #8c8c8c 55%,
          #6b6b6b 70%,
          #3d3d3d 85%,
          #1a1a1a 100%
        );
        background-size: 300% 300%;
        animation: gradientShift 4s ease-in-out infinite alternate;
      }

      /* O Vidro Esfumaçado */
      .preloader__glass {
        position: absolute;
        top: 0;
        width: 50%;
        height: 100dvh;
        z-index: 5;
        will-change: transform, background, backdrop-filter;
        animation: glassBreathe 4s ease-in-out infinite; 
      }
      
      /* Micro-bordas para dar o efeito de espessura de vidro contra o fundo preto */
      .preloader__glass--left { 
        left: 0; 
        border-right: 1px solid rgba(255, 255, 255, 0.03);
      }
      .preloader__glass--right { 
        right: 0; 
        border-left: 1px solid rgba(255, 255, 255, 0.03);
      }

      .preloader__logo {
        position: absolute;
        inset: 0;
        z-index: 10;
        width: 40vw;
        max-width: 400px;
        height: fit-content;
        margin: auto;
        animation: logoPulse 4s ease-in-out infinite;
      }

      @media (max-width: 768px) {
        .preloader__glass--right { display: none !important; }
        .preloader__glass--left { width: 100% !important; border-right: none; }
      }
    </style>
  </head>

  <body>
    <Preloader />
    
    <slot />
  
    <script>
      import { initScrollEngine } from '../scripts/scrollEngine';
      initScrollEngine(); 
      
    </script>
  </body>
</html>

<style is:global>
  :root {
    --hero-bg: #e7e7e7; 
    --font-sans: 'Montserrat', sans-serif;
    --color-text: #F4F4F4;        /* branco suave */
    --color-overlay: #080D0B;     /* preto com subtom verde */
    --header-text-color: #F4F4F4;
  }

  /* 1. Reset de box model */
  *,
  *::before,
  *::after {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  /* 2. Remover decorações de links e listas */
  a {
    text-decoration: none;
    color: inherit;
  }

  ul,
  ol {
    list-style: none;
  }

  body {
    font-family: var(--font-sans);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    overflow-x: hidden;
    line-height: 1.5;
    text-rendering: geometricPrecision;
    font-feature-settings: "kern" 1;
    font-kerning: normal;
    letter-spacing: -0.02em;
    background-color: transparent; 
  }

  /* 4. Imagens como bloco */
  img,
  svg,
  video {
    display: block;
    max-width: 100%;
    height: auto;
  }

  canvas {
    display: block;
  }

  /* 5. Reset de botões */
  button {
    font: inherit;
    border: none;
    cursor: pointer;
    background: none;
  }

  /* 6. Tipografia base para headings */
  h1, h2, h3, h4, h5, h6 {
    font-weight: normal;
    line-height: 1.2;
  }

  /* 7. Inputs e selects */
  input, textarea, select {
    font: inherit;
    color: inherit;
  }
</style>